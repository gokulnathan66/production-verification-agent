FROM python:3.11-slim

ARG AGENT_DIR
WORKDIR /app

# Copy shared module
COPY src/shared /app/shared

# Copy agent files
COPY src/${AGENT_DIR}/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy all agent files (including prompt.txt for orchestrator)
COPY src/${AGENT_DIR}/ .

CMD ["python", "agent.py"]
